{"type": "excalidraw", "version": 2, "source": "https://excalidraw.com", "elements": [{"id": "title", "type": "text", "x": 150, "y": 10, "width": 600, "height": 40, "text": "Evolution of AI agentic patterns: where did rigor relocate?", "fontSize": 22, "fontFamily": 5, "textAlign": "center", "baseline": 28, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": [], "roundness": null, "seed": 1, "version": 1, "versionNonce": 1, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"id": "era1-box", "type": "rectangle", "x": 30, "y": 70, "width": 260, "height": 300, "strokeColor": "#1971c2", "backgroundColor": "#d0ebff", "fillStyle": "solid", "strokeWidth": 2, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": ["era1"], "roundness": {"type": 3}, "seed": 2, "version": 1, "versionNonce": 2, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"id": "era1-title", "type": "text", "x": 60, "y": 80, "width": 200, "height": 30, "text": "Prompt Engineering\n      2022-2024", "fontSize": 16, "fontFamily": 5, "textAlign": "center", "baseline": 22, "strokeColor": "#1971c2", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": ["era1"], "roundness": null, "seed": 3, "version": 1, "versionNonce": 3, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"id": "era1-q", "type": "text", "x": 50, "y": 130, "width": 220, "height": 25, "text": "\"What words should I say?\"", "fontSize": 14, "fontFamily": 5, "textAlign": "center", "baseline": 18, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": ["era1"], "roundness": null, "seed": 4, "version": 1, "versionNonce": 4, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"id": "era1-events", "type": "text", "x": 45, "y": 165, "width": 230, "height": 180, "text": "2022.06  GitHub Copilot launch\n2022.11  ChatGPT public release\n2022.01  Chain-of-Thought\n2022.10  ReAct\n2023.03  Cursor debut\n2023.05  Tree-of-Thought\n2024.03  Ng 4 Patterns\n2024.12  Anthropic Agents guide\n\nRigor lives in: prompt text\n Smell: Blind Prompting", "fontSize": 11, "fontFamily": 5, "textAlign": "left", "baseline": 14, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": ["era1"], "roundness": null, "seed": 5, "version": 1, "versionNonce": 5, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"id": "era2-box", "type": "rectangle", "x": 320, "y": 70, "width": 260, "height": 300, "strokeColor": "#2f9e44", "backgroundColor": "#d8f5a2", "fillStyle": "solid", "strokeWidth": 2, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": ["era2"], "roundness": {"type": 3}, "seed": 6, "version": 1, "versionNonce": 6, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"id": "era2-title", "type": "text", "x": 340, "y": 80, "width": 220, "height": 30, "text": "Context Engineering\n           2025", "fontSize": 16, "fontFamily": 5, "textAlign": "center", "baseline": 22, "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": ["era2"], "roundness": null, "seed": 7, "version": 1, "versionNonce": 7, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"id": "era2-q", "type": "text", "x": 340, "y": 130, "width": 220, "height": 25, "text": "\"What information should I provide?\"", "fontSize": 14, "fontFamily": 5, "textAlign": "center", "baseline": 18, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": ["era2"], "roundness": null, "seed": 8, "version": 1, "versionNonce": 8, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"id": "era2-events", "type": "text", "x": 335, "y": 165, "width": 230, "height": 180, "text": "2025.02  Vibe Coding (Karpathy)\n2025.06  Lütke tweet\n2025.06  Karpathy reply\n2025.07  Manus 6 principles\n2025.09  Anthropic CE guide\n2025.10  ACE paper\n2025.12  Google ADK\n\n Rigor lives in: context window\n Smell: no system", "fontSize": 11, "fontFamily": 5, "textAlign": "left", "baseline": 14, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": ["era2"], "roundness": null, "seed": 9, "version": 1, "versionNonce": 9, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"id": "era3-box", "type": "rectangle", "x": 610, "y": 70, "width": 260, "height": 300, "strokeColor": "#e8590c", "backgroundColor": "#ffe8cc", "fillStyle": "solid", "strokeWidth": 2, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": ["era3"], "roundness": {"type": 3}, "seed": 10, "version": 1, "versionNonce": 10, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"id": "era3-title", "type": "text", "x": 630, "y": 80, "width": 220, "height": 30, "text": "Harness Engineering\n          2026~", "fontSize": 16, "fontFamily": 5, "textAlign": "center", "baseline": 22, "strokeColor": "#e8590c", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": ["era3"], "roundness": null, "seed": 11, "version": 1, "versionNonce": 11, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"id": "era3-q", "type": "text", "x": 630, "y": 130, "width": 220, "height": 25, "text": "\"What system should I build?\"", "fontSize": 14, "fontFamily": 5, "textAlign": "center", "baseline": 18, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": ["era3"], "roundness": null, "seed": 12, "version": 1, "versionNonce": 12, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"id": "era3-events", "type": "text", "x": 625, "y": 165, "width": 230, "height": 180, "text": "2026.01  Schmid Agent Harness\n2026.02  Hashimoto naming\n2026.02  OpenAI Codex experiment\n2026.02  Fowler 2x2 framework\n2026.02  Mollick framework\n2026.03  Anthropic 3-Agent\n\n Rigor lives in: system architecture\n Agent = Model + Harness", "fontSize": 11, "fontFamily": 5, "textAlign": "left", "baseline": 14, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": ["era3"], "roundness": null, "seed": 13, "version": 1, "versionNonce": 13, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"id": "arrow1", "type": "text", "x": 295, "y": 200, "width": 20, "height": 30, "text": "->", "fontSize": 24, "fontFamily": 5, "textAlign": "center", "baseline": 22, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": [], "roundness": null, "seed": 14, "version": 1, "versionNonce": 14, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"id": "arrow2", "type": "text", "x": 585, "y": 200, "width": 20, "height": 30, "text": "->", "fontSize": 24, "fontFamily": 5, "textAlign": "center", "baseline": 22, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": [], "roundness": null, "seed": 15, "version": 1, "versionNonce": 15, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}, {"id": "bottom-note", "type": "text", "x": 200, "y": 390, "width": 500, "height": 30, "text": "Each era subsumes the previous one rather than replacing it — Chad Fowler, \"Relocating Rigor\"", "fontSize": 13, "fontFamily": 5, "textAlign": "center", "baseline": 18, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 1, "opacity": 100, "angle": 0, "groupIds": [], "roundness": null, "seed": 16, "version": 1, "versionNonce": 16, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false}], "appState": {"gridSize": null, "viewBackgroundColor": "#ffffff"}, "files": {}}